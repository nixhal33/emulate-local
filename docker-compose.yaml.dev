version: "3.9"

services:
  emulate:
    container_name: emulate-app
    build:
      context: .
      dockerfile: Dockerfile
    image: emulate:app
    restart: unless-stopped
    expose:
      - "80"
      - "4000"
      - "4001"
      - "4002"
      - "4003"
      - "4004"
    environment:
      NODE_ENV: production
      HOST: 0.0.0.0
      PORT: 4000
      PUBLIC_HOST: localhost
    healthcheck:
      test: ["CMD","node","-e","fetch('http://127.0.0.1:4000').then(r=>process.exit(r.ok||r.status===404?0:1)).catch(()=>process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - internal

  nginx:
    container_name: emulate-nginx
    image: nginx:1.27-alpine
    restart: unless-stopped
    depends_on:
      - emulate
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      - internal

networks:
  internal:
    driver: bridge
